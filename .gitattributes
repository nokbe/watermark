# 自动处理换行符
* text=auto

# Windows 批处理文件
*.bat text eol=crlf

# Shell 脚本和 Python
*.sh text eol=lf
*.py text eol=lf

# Android 项目文件
*.xml text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf

# 图片和二进制文件不转换
*.png binary
*.jpg binary
*.gif binary
*.webp binary
*.apk binary
*.aar binary
