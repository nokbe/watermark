<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WatermarkApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 主色调 - 夜间模式使用深色调 -->
        <item name="colorPrimary">@color/primary_blue_dark</item>
        <item name="colorPrimaryVariant">@color/primary_blue</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- 次色调 -->
        <item name="colorSecondary">@color/primary_blue</item>
        <item name="colorSecondaryVariant">@color/primary_blue_light</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- 背景色 - 夜间模式使用深色背景 -->
        <item name="android:colorBackground">#1F2937</item>
        <item name="colorSurface">#374151</item>
        <item name="colorOnSurface">#F3F4F6</item>
    </style>

    <style name="Theme.WatermarkApp" parent="Base.Theme.WatermarkApp" />
</resources>
